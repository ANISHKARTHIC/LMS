SECRET_KEY=replace-with-a-strong-secret
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# Local SQLite is used when DATABASE_URL is not set.
# For PostgreSQL on Render/Heroku, use:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
DATABASE_URL=

AI_PROVIDER=gemini

# Free-tier option (recommended): Google Gemini API key from AI Studio
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.0-flash
GEMINI_TEXT_MODEL=gemini-2.0-flash
# Optional fallback model; leave empty unless verified for your account
GEMINI_FALLBACK_MODEL=
GEMINI_MAX_RETRIES=4

# Optional paid fallback
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini

# Optional: require authentication for student pages
STUDENT_LOGIN_REQUIRED=False

# Upload control in MB
MAX_UPLOAD_SIZE_MB=5

# Security settings (recommended for production)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Predefined default admin credentials (local/dev convenience)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin123

